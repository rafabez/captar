# CAPTAR production environment variables
# Copy this to .env and fill in the values

# Database
DB_PASSWORD=generate-a-strong-random-password

# App secrets
SECRET_KEY=generate-a-strong-secret-key-at-least-32-chars
ENCRYPTION_KEY=generate-a-base64-encoded-256-bit-key

# Clerk authentication (from https://dashboard.clerk.com)
CLERK_PUBLISHABLE_KEY=pk_test_your-publishable-key
CLERK_SECRET_KEY=sk_test_your-secret-key

# Domain
CAPTAR_DOMAIN=https://your-domain.com
